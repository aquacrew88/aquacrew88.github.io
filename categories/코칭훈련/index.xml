&lt;th>총 거리 (m)&lt;/th>
&lt;/tr>
&lt;/thead>
&lt;tbody>
&lt;tr>
&lt;td>1단계&lt;/td>
&lt;td>50&lt;/td>
&lt;td>80초&lt;/td>
&lt;td>10&lt;/td>
&lt;td>500&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td>2단계&lt;/td>
&lt;td>50&lt;/td>
&lt;td>70초&lt;/td>
&lt;td>8&lt;/td>
&lt;td>400&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td>3단계&lt;/td>
&lt;td>50&lt;/td>
&lt;td>65초&lt;/td>
&lt;td>6&lt;/td>
&lt;td>300&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td>4단계&lt;/td>
&lt;td>50&lt;/td>
